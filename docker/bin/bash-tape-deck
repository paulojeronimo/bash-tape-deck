#!/usr/bin/env bash
set -euo pipefail

engine_dir="${BASH_TAPE_ENGINE_DIR:-/opt/bash-tape-deck}"

usage() {
  cat <<'EOF'
Usage:
  bash-tape-deck play [N]
  bash-tape-deck rewind [N]
  bash-tape-deck play <steps-dir> [N]
  bash-tape-deck rewind <steps-dir> [N]
  bash-tape-deck help

Examples:
  bash-tape-deck play
  bash-tape-deck play 2
  bash-tape-deck rewind 2
  bash-tape-deck play samples/fibonacci
  bash-tape-deck play samples/fibonacci 2
  bash-tape-deck rewind samples/fibonacci 2
EOF
}

resolve_steps_args() {
  local default_steps_dir="${BASH_TAPE_DEFAULT_STEPS_DIR:-}"

  if [ -z "$default_steps_dir" ]; then
    echo "Missing steps directory and BASH_TAPE_DEFAULT_STEPS_DIR is not set." >&2
    echo "Use: bash-tape-deck play <steps-dir> [N]" >&2
    exit 1
  fi

  printf '%s' "$default_steps_dir"
}

parse_play_rewind_args() {
  local default_steps_dir
  default_steps_dir="$(resolve_steps_args)"

  parsed_steps_dir="$default_steps_dir"
  parsed_step_number=""

  case "$#" in
    0)
      return 0
      ;;
    1)
      if [ -d "$1" ]; then
        parsed_steps_dir="$1"
        return 0
      fi
      if [[ "$1" =~ ^[0-9]+$ ]]; then
        parsed_step_number="$1"
        return 0
      fi
      echo "Invalid argument: $1" >&2
      echo "Use: <steps-dir> or step number [N]" >&2
      exit 1
      ;;
    2)
      if [ ! -d "$1" ]; then
        echo "Steps directory not found: $1" >&2
        exit 1
      fi
      if ! [[ "$2" =~ ^[0-9]+$ ]]; then
        echo "Invalid step number: $2" >&2
        exit 1
      fi
      parsed_steps_dir="$1"
      parsed_step_number="$2"
      return 0
      ;;
    *)
      echo "Too many arguments." >&2
      echo "Use: play [N] or play <steps-dir> [N]" >&2
      exit 1
      ;;
  esac
}

parsed_steps_dir=""
parsed_step_number=""

action="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$action" in
  play)
    export BASH_TAPE_RUN_WORKDIR="${BASH_TAPE_RUN_WORKDIR:-/workspace}"
    parse_play_rewind_args "$@"
    if [ -n "$parsed_step_number" ]; then
      exec "$engine_dir/play.sh" "$parsed_steps_dir" "$parsed_step_number"
    fi
    exec "$engine_dir/play.sh" "$parsed_steps_dir"
    ;;
  rewind)
    export BASH_TAPE_RUN_WORKDIR="${BASH_TAPE_RUN_WORKDIR:-/workspace}"
    parse_play_rewind_args "$@"
    if [ -n "$parsed_step_number" ]; then
      exec "$engine_dir/rewind.sh" "$parsed_steps_dir" "$parsed_step_number"
    fi
    exec "$engine_dir/rewind.sh" "$parsed_steps_dir"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $action" >&2
    usage >&2
    exit 1
    ;;
esac
